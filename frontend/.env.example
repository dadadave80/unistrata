# Reown AppKit project id — create one at https://dashboard.reown.com (free).
# Wallet connection won't work until this is set.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Origin-chain RPC for live hook reads (Unichain Sepolia, chainId 1301).
# Defaults to the public endpoint if unset.
NEXT_PUBLIC_UNICHAIN_RPC=https://sepolia.unichain.org
