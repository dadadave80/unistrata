{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/protocol/**",
              "ds-runtime.js",
              "ui_kits/strata-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Spline Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Spline Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|dot|live|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, dot, live, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|senior|junior|positive|negative|live)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'senior' | 'junior' | 'positive' | 'negative' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|senior|junior|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'senior' | 'junior' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EpochCountdown'] > JSXAttribute > JSXIdentifier[name!=/^(?:epoch|secondsLeft|epochLength|running|onSettle|key|ref|className|style|children)$/]",
        "message": "<EpochCountdown> doesn't accept that prop. Declared props: epoch, secondsLeft, epochLength, running, onSettle."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventFeed'] > JSXAttribute > JSXIdentifier[name!=/^(?:events|title|maxHeight|explorerBase|key|ref|className|style|children)$/]",
        "message": "<EventFeed> doesn't accept that prop. Declared props: events, title, maxHeight, explorerBase."
      },
      {
        "selector": "JSXOpeningElement[name.name='GaugeThreshold'] > JSXAttribute > JSXIdentifier[name!=/^(?:at|color|key|ref|className|style|children)$/]",
        "message": "<GaugeThreshold> doesn't accept that prop. Declared props: at, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoneyChartSeries'] > JSXAttribute > JSXIdentifier[name!=/^(?:hodl|lp|senior|junior|key|ref|className|style|children)$/]",
        "message": "<MoneyChartSeries> doesn't accept that prop. Declared props: hodl, lp, senior, junior."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberTicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|decimals|prefix|suffix|commas|duration|key|ref|className|style|children)$/]",
        "message": "<NumberTicker> doesn't accept that prop. Declared props: value, decimals, prefix, suffix, commas, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|actions|accent|variant|padded|headless|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: eyebrow, title, actions, accent, variant, padded, headless, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:senior|junior)$/]",
        "message": "<Panel> accent must be one of 'senior' | 'junior'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|sunken)$/]",
        "message": "<Panel> variant must be one of 'default' | 'sunken'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|deltaDir|tone|size|children|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: label, value, unit, delta, deltaDir, tone, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='deltaDir'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<Stat> deltaDir must be one of 'up' | 'down' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|senior|junior)$/]",
        "message": "<Stat> tone must be one of 'default' | 'senior' | 'junior'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Stat> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StrataCore'] > JSXAttribute > JSXIdentifier[name!=/^(?:seniorNav|juniorNav|scaleMax|height|sweepKey|glyph|showScale|key|ref|className|style|children)$/]",
        "message": "<StrataCore> doesn't accept that prop. Declared props: seniorNav, juniorNav, scaleMax, height, sweepKey, glyph, showScale."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrancheCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tranche|apr|aprLabel|name|role|rows|capacityPct|capacityLabel|footnote|selected|onSelect|key|ref|className|style|children)$/]",
        "message": "<TrancheCard> doesn't accept that prop. Declared props: tranche, apr, aprLabel, name, role, rows, capacityPct, capacityLabel, footnote, selected, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrancheCard'] > JSXAttribute[name.name='tranche'] > Literal[value!=/^(?:senior|junior)$/]",
        "message": "<TrancheCard> tranche must be one of 'senior' | 'junior'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
